# ============================================================================
# Shared
# ============================================================================

# LiteLLM / LLM
MODEL_NAME=
LITELLM_PROXY_URL=
LITELLM_API_KEY=

# MongoDB
MONGODB_URI=
MONGODB_DB=modus
MONGODB_SEGMENTS_COLLECTION=segments
MONGODB_SECTIONS_COLLECTION=sections
MONGODB_CHAPTERS_COLLECTION=chapters

# Token-count encoding
TOKEN_COUNT_ENCODING=cl100k_base

# Graph
GRAPH_RECURSION_LIMIT=100

# Logging
LOG_LEVEL=INFO

# ============================================================================
# Doc-processing pipeline
# ============================================================================

# Datalab
DATALAB_API_KEY=

# Segment analyzer
SEGMENT_ANALYZER_CONCURRENCY=10

# Aggregation
SECTION_AGGREGATOR_CONCURRENCY=10
CHAPTER_AGGREGATOR_CONCURRENCY=10

# ============================================================================
# QnA pipeline
# ============================================================================

# MongoDB MCP (legacy fallback)
MDB_MCP_CONNECTION_STRING=

# Preprocessed markdown directory (defaults to <repo-root>/output/preprocessed-output)
# PREPROCESSED_OUTPUT_DIR=

# Footer regex pair (per-doc configurable; defaults are for ICICI Annual Report 2023-24)
# FOOTER_REGEX_LEFT=^\*{0,2}\s*(\d+)\s*\|\s*Annual Report 2023-24\s*\*{0,2}$
# FOOTER_REGEX_RIGHT=^\*{0,2}\s*Annual Report 2023-24\s*\|\s*(\d+)\s*\*{0,2}$

# GRA budgets
GREP_MATCH_LIMIT=20
GREP_SNIPPET_CHARS=200
GET_PAGE_TEXT_TOKEN_CAP=8000
WORKER_PARALLEL_CAP=8
PLAN_MAX_TASKS=10
GRA_INNER_RECURSION_LIMIT=25
WORKER_INNER_RECURSION_LIMIT=15
DOCUMENT_AGENT_RECURSION_LIMIT=15

# PageIndex MCP
PAGEINDEX_API_KEY=

# LangSmith
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT="Modus"

# Chainlit
CHAINLIT_AUTH_SECRET=

# Prompt Versions
SUPERVISOR_PROMPT_VERSION=v2
